;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Path of the crystal"
config/description="Las profundidades esconden un poder invaluable: los Cristales Ancestrales. Como miembro de una unidad militar de élite, tu misión es recuperarlos mientras sobrevives a feroces criaturas y peligros ocultos en cada caverna. Cada cristal te acerca al siguiente desafío, pero también a un enemigo cada vez más poderoso. ¿Estás listo para completar la misión?"
config/version="1.2"
run/main_scene="uid://bpcn5y0g2yv6u"
config/features=PackedStringArray("4.6", "GL Compatibility")
